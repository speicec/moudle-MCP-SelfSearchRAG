{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "resolveJsonModule": true,

    "paths": {
      "@types/*": ["./src/types/*"],
      "@storage/*": ["./src/storage/*"],
      "@plugins/*": ["./src/plugins/*"],
      "@chunking/*": ["./src/chunking/*"],
      "@embedding/*": ["./src/embedding/*"],
      "@query/*": ["./src/query/*"],
      "@retrieval/*": ["./src/retrieval/*"],
      "@harness/*": ["./src/harness/*"],
      "@server/*": ["./src/server/*"],
      "@config/*": ["./src/config/*"],
      "@utils/*": ["./src/utils/*"]
    },

    "typeRoots": ["./node_modules/@types", "./src/types"]
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "tests"]
}