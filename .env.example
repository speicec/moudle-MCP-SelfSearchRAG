# Embedding Configuration
# Supports both API-based (OpenAI-compatible) and local (transformers.js) embedding

# Embedding mode: 'local' (transformers.js) or 'api' (OpenAI-compatible)
# Default: 'local' - no API key required, runs multilingual models locally
EMBEDDING_MODE=local

# Local Model Configuration (when EMBEDDING_MODE=local)
# Text model: supports 100+ languages including Chinese and English
LOCAL_TEXT_MODEL=multilingual-e5-small
# Multimodal model: enables text-to-image and image-to-text search
LOCAL_MULTIMODAL_MODEL=clip-vit-base-patch32

# API Configuration (when EMBEDDING_MODE=api)
# Supports OpenAI-compatible APIs (OpenAI, DeepSeek, etc.)

# API Key for embedding service
EMBEDDING_API_KEY=your-api-key-here

# API Base URL (default: OpenAI, or use DeepSeek/other compatible service)
# OpenAI: https://api.openai.com/v1
# DeepSeek: https://api.deepseek.com
EMBEDDING_API_BASE_URL=https://api.openai.com/v1

# Embedding model (default: text-embedding-3-small)
# OpenAI: text-embedding-3-small, text-embedding-3-large, text-embedding-ada-002
# DeepSeek: (check if embedding API is available)
EMBEDDING_MODEL=text-embedding-3-small

# Model Cache Directory (optional)
# Default: ~/.cache/huggingface/hub/ (or %USERPROFILE%\.cache\huggingface\hub\ on Windows)
# TRANSFORMERS_CACHE=/path/to/custom/cache

# Legacy support (will be deprecated)
# OPENAI_API_KEY=your-api-key-here