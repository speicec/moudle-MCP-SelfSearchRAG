{
  "name": "enhanced-rag-mcp-server",
  "version": "0.1.0",
  "description": "Enhanced RAG system with multimodal support and complex PDF parsing, exposed via MCP Server",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "rag-mcp-server": "dist/mcp/server.js"
  },
  "scripts": {
    "build": "tsc && vite build",
    "build:fast": "esbuild src/index.ts src/mcp/server.ts --outdir=dist --format=esm --platform=node --target=ES2022 --bundle",
    "build:frontend": "vite build",
    "dev": "tsc --watch",
    "dev:frontend": "vite dev",
    "dev:server": "tsc && node dist/server/main-server.js",
    "start": "node dist/index.js",
    "start:server": "node dist/server/main-server.js",
    "mcp": "node dist/mcp/server.js",
    "download-models": "npx tsx scripts/download-models.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "rag",
    "mcp",
    "multimodal",
    "pdf-parsing",
    "vector-search"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.27.0",
    "@fastify/multipart": "^8.0.0",
    "@fastify/static": "^7.0.0",
    "@fastify/websocket": "^10.0.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@xenova/transformers": "^2.17.2",
    "chromadb": "^1.5.0",
    "dotenv": "^17.4.1",
    "fastify": "^4.26.0",
    "pdf-parse": "^1.1.1",
    "pino-pretty": "^13.1.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "uuid": "^9.0.0",
    "zod": "^3.22.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/pdf-parse": "^1.1.1",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/uuid": "^9.0.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.0",
    "esbuild": "^0.19.0",
    "eslint": "^8.56.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vitest": "^1.0.0"
  }
}
