## 三、Skill 与 Spec 协作机制

### 3.1 Skill 调用时机

```typescript
// Skill 调用决策树
interface SkillInvocationDecision {
  task: Task;
  recommendedSkills: SkillRecommendation[];
}

function recommendSkills(task: Task): SkillRecommendation[] {
  const recommendations: SkillRecommendation[] = [];

  // 需求分析阶段
  if (task.phase === 'analysis') {
    recommendations.push({
      skill: 'requirements-analyzer',
      reason: '分析需求，生成/更新 Spec',
      priority: 'high'
    });
  }

  // 编码阶段
  if (task.phase === 'implementation') {
    recommendations.push({
      skill: 'coder',
      reason: '根据 Spec 生成代码',
      priority: 'high'
    });
  }

  // 测试阶段
  if (task.phase === 'testing') {
    recommendations.push({
      skill: 'tdd-tester',
      reason: '生成测试用例，运行测试',
      priority: 'high'
    });
  }

  // 审核阶段
  if (task.phase === 'review') {
    recommendations.push({
      skill: 'reviewer',
      reason: '代码审核，检查 Spec 合规性',
      priority: 'medium'
    });
  }

  // CI/CD 阶段
  if (task.phase === 'deployment') {
    recommendations.push({
      skill: 'cicd-orchestrator',
      reason: '生成 Dockerfile 和 CI 配置',
      priority: 'medium'
    });
  }

  return recommendations;
}
```

