# Spec 驱动开发流程指南

## 概述

本文档定义如何使用 Spec 文档驱动 Agent 正确执行开发流程，以及如何通过 Skill 实现自动化。

---

## 一、Spec 驱动开发流程

### 1.1 核心理念

```
Spec (规格) → Agent (执行) → Skill (辅助) → Code (产出)
    ↑                                        ↓
    └──────────── Verify (验证) ←────────────┘
```

**原则**：
- Spec 是契约，Agent 必须遵守
- Skill 是工具，Agent 按需调用
- 验证是闭环，确保符合 Spec

### 1.2 开发流程图

```
┌─────────────────────────────────────────────────────────────────────┐
│                    Spec 驱动开发流程                                  │
│                                                                     │
│  ┌─────────┐    ┌─────────┐    ┌─────────┐    ┌─────────┐          │
│  │ 1.读取  │ →  │ 2.分析  │ →  │ 3.实现  │ →  │ 4.验证  │          │
│  │  Spec   │    │  任务   │    │  代码   │    │  结果   │          │
│  └─────────┘    └─────────┘    └─────────┘    └─────────┘          │
│       ↑                                             ↓               │
│       └──────────── 5.迭代 ←────────────────────────┘               │
│                                                                     │
│  辅助 Skill:                                                        │
│  ┌─────────────┐ ┌─────────────┐ ┌─────────────┐ ┌─────────────┐    │
│  │requirements │ │   coder     │ │  reviewer   │ │  tdd-tester │    │
│  │  -analyzer  │ │             │ │             │ │             │    │
│  └─────────────┘ └─────────────┘ └─────────────┘ └─────────────┘    │
└─────────────────────────────────────────────────────────────────────┘
```

### 1.3 详细步骤

#### Step 1: 读取 Spec

```typescript
// Agent 启动时的标准流程
async function initializeDevelopment(): Promise<DevelopmentContext> {
  // 1. 读取项目总览
  const overview = await readSpec('specs/overview.md');

  // 2. 读取当前节点排期
  const schedule = await readSpec('specs/schedule.md');
  const currentNode = schedule.currentNode;  // Node A/B/C/D

  // 3. 读取相关技术规格
  const relevantSpecs = await loadRelevantSpecs(currentNode);

  // 4. 构建开发上下文
  return {
    project: overview,
    currentNode,
    specs: relevantSpecs,
    status: 'ready'
  };
}

// 加载节点相关的 Spec
async function loadRelevantSpecs(node: Node): Promise<SpecDict> {
  const specMap: Record<string, string[]> = {
    'Node A': [
      'directory-structure.md',
      'plugin-system.md',
      'architecture.md'
    ],
    'Node B': [
      'query-layer.md',
      'chunking-layer.md',
      'reranker.md',
      'offline-search.md',
      'long-tail-query.md'
    ],
    'Node C': [
      'tools.md',
      'resources.md',
      'prompts.md',
      'harness.md'
    ],
    'Node D': [
      'evaluation.md',
      'multimodal.md'
    ]
  };

  const specs: SpecDict = {};
  for (const specName of specMap[node.name]) {
    specs[specName] = await readSpec(`specs/${specName}`);
  }
  return specs;
}
```

#### Step 2: 分析任务

```typescript
// 基于 Spec 分析任务
async function analyzeTasks(context: DevelopmentContext): Promise<TaskList> {
  // 1. 从 schedule.md 获取当前节点任务
  const nodeTasks = context.project.schedule[context.currentNode];

  // 2. 匹配 Spec 定义
  const tasksWithSpec = nodeTasks.map(task => ({
    ...task,
    specReference: findSpecReference(task, context.specs)
  }));

  // 3. 验证任务完整性
  const validated = validateTasks(tasksWithSpec);

  return validated;
}

// 匹配 Spec 引用
function findSpecReference(task: Task, specs: SpecDict): SpecReference {
  // 任务 -> Spec 映射表
  const taskToSpec: Record<string, string> = {
    // Node A
    'A.1': 'directory-structure.md#项目初始化',
    'A.2': 'architecture.md#存储层',
    'A.3': 'plugin-system.md',

    // Node B
    'B.1': 'chunking-layer.md',
    'B.2': 'plugin-system.md#Embedder插件',
    'B.3': 'query-layer.md#多路召回',
    'B.4': 'reranker.md',
    'B.5': 'offline-search.md',
    'B.6': 'harness.md#反馈回路',

    // Node C
    'C.1': 'tools.md',
    'C.2': 'resources.md',
    'C.3': 'prompts.md',
    'C.4': 'harness.md#观测审计',
    'C.5': 'harness.md#流程编排',

    // Node D
    'D.1': 'evaluation.md',
    'D.2': 'evaluation.md#回归测试',
    'D.3': 'plugin-system.md#CI/CD'
  };

  const specPath = taskToSpec[task.id];
  if (!specPath) {
    throw new Error(`No spec found for task ${task.id}`);
  }

  return parseSpecReference(specPath);
}
```

#### Step 3: 实现代码

```typescript
// 按照 Spec 实现代码
async function implementTask(task: Task, spec: SpecReference): Promise<CodeResult> {
  // 1. 读取 Spec 定义
  const specContent = await readSpecSection(spec);

  // 2. 提取接口定义
  const interfaces = extractInterfaces(specContent);

  // 3. 提取验收标准
  const criteria = extractAcceptanceCriteria(specContent);

  // 4. 生成代码
  const code = await generateCode({
    task,
    interfaces,
    criteria,
    existingCode: await loadExistingCode()
  });

  // 5. 写入文件
  await writeCode(code);

  return { files: code.files, status: 'implemented' };
}
```

#### Step 4: 验证结果

```typescript
// 验证实现是否符合 Spec
async function verifyImplementation(task: Task, result: CodeResult): Promise<VerificationResult> {
  // 1. 类型检查
  const typeCheck = await runTypeCheck(result.files);

  // 2. 单元测试
  const tests = await runTests(result.files);

  // 3. Spec 一致性检查
  const specCompliance = await checkSpecCompliance(task, result);

  // 4. 验收标准检查
  const acceptance = await checkAcceptanceCriteria(task, result);

  return {
    typeCheck: typeCheck.success,
    tests: tests.passRate,
    specCompliance: specCompliance.score,
    acceptance: acceptance.passed,
    overall: typeCheck.success && tests.passRate > 0.8 && specCompliance.score > 0.9 && acceptance.passed
  };
}
```

