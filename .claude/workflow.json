### 3.3 Skill 编程接口

```typescript
// Skill 基础接口
interface Skill {
  name: string;
  description: string;
  inputSchema: JSONSchema;
  outputSchema: JSONSchema;

  execute(input: SkillInput, context: SkillContext): Promise<SkillOutput>;
}

interface SkillContext {
  // Spec 访问
  specs: {
    read(path: string): Promise<string>;
    getInterface(specName: string, interfaceName: string): Promise<InterfaceDef>;
    getAcceptanceCriteria(specName: string): Promise<AcceptanceCriteria[]>;
  };

  // 文件操作
  files: {
    read(path: string): Promise<string>;
    write(path: string, content: string): Promise<void>;
    exists(path: string): Promise<boolean>;
  };

  // 测试运行
  test: {
    run(testFile: string): Promise<TestResult>;
    runAll(): Promise<TestResult[]>;
  };

  // 类型检查
  typeCheck: {
    check(): Promise<TypeCheckResult>;
  };
}
```

